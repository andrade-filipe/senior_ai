{# agent.py.j2 — generated by transpiler; do not edit manually.
   Template vars: name, description, model, instruction,
                  mcp_servers (list of {name, url, tool_filter}),
                  http_tools  (list of {name, base_url, openapi_url}),
                  pii_enabled (bool)
#}
"""{{ name }} agent — generated by transpiler."""

from __future__ import annotations

import os

from google.adk.agents import LlmAgent
from google.adk.tools.mcp_tool import McpToolset
from google.adk.tools.mcp_tool.mcp_session_manager import StreamableHTTPConnectionParams
{% if http_tools %}
from google.adk.tools.openapi_tool.openapi_spec_parser.openapi_toolset import OpenAPIToolset
{% endif %}

_SSE_HEADERS: dict[str, str] = {
    "Accept": "application/json, text/event-stream",
}
{% for srv in mcp_servers %}

{{ srv.name | replace("-", "_") }}_toolset = McpToolset(
    connection_params=StreamableHTTPConnectionParams(
        url=os.environ.get({{ (srv.name.upper().replace("-", "_") + "_MCP_URL") | tojson }}, {{ srv.url | tojson }}),
        headers=_SSE_HEADERS,
    ),
{% if srv.tool_filter is not none %}
    tool_filter={{ srv.tool_filter | tojson }},
{% endif %}
)
{% endfor %}
{% for tool in http_tools %}

{{ tool.name | replace("-", "_") }}_toolset = OpenAPIToolset(
    spec_url=os.environ.get({{ (tool.name.upper().replace("-", "_") + "_OPENAPI_URL") | tojson }}, {{ (tool.openapi_url if tool.openapi_url else (tool.base_url + "/openapi.json")) | tojson }}),
)
{% endfor %}
{% if pii_enabled %}


def _pii_callback(
    callback_context: object,
    llm_request: object,
) -> None:
    """Apply PII masking to every LLM request (ADR-0003, second layer).

    Bloco 0005 (security) provides pii_mask at runtime.

    Args:
        callback_context: ADK callback context (unused; present for signature compliance).
        llm_request: ADK LLM request object whose contents are masked in-place.
    """
    # Local import: avoids hard dep at module-load time when security not yet installed.
    # Install security/ (Bloco 0005) before running the agent.
    from security import pii_mask  # noqa: PLC0415

    if not hasattr(llm_request, "contents"):
        return
    for content in llm_request.contents:
        if not hasattr(content, "parts"):
            continue
        for part in content.parts:
            if hasattr(part, "text") and isinstance(part.text, str):
                result = pii_mask(part.text)
                part.text = result.masked_text

{% endif %}

root_agent = LlmAgent(
    name={{ name | tojson }},
    model={{ model | tojson }},
    description={{ description | tojson }},
    instruction={{ instruction | tojson }},
    tools=[
{% for srv in mcp_servers %}
        {{ srv.name | replace("-", "_") }}_toolset,
{% endfor %}
{% for tool in http_tools %}
        {{ tool.name | replace("-", "_") }}_toolset,
{% endfor %}
    ],
{% if pii_enabled %}
    before_model_callback=_pii_callback,
{% endif %}
)
