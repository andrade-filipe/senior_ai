# =============================================================================
# .env.example — copy to .env and customize. Full surface is documented in
# docs/CONFIGURATION.md and ADR-0009.
# =============================================================================

# --- Gemini API (ADR-0005) ---
# Required: obtain from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=<your-google-api-key>
# Set to FALSE to use direct Gemini API (not Vertex AI). Do not change unless
# deploying on GCP with Vertex AI enabled.
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# --- Agent runtime (generated_agent) ---
# Default swapped to gemini-2.5-flash-lite after 2026-04-20 incident
# (gemini-2.5-flash function-calling pool saturation returned HTTP 503).
GEMINI_MODEL=gemini-2.5-flash-lite
# Wall-clock timeout of the whole agent run (seconds).
AGENT_TIMEOUT_SECONDS=300
# HTTP timeout when the agent fetches scheduling-api's OpenAPI spec at boot (seconds).
SCHEDULING_OPENAPI_FETCH_TIMEOUT_SECONDS=10
# Wall-clock timeout envelope for the CLI-orchestrated pre-OCR MCP call
# (connect + initialize + call_tool). ADR-0010 / spec 0010.
PREOCR_MCP_TIMEOUT_SECONDS=10
# Number of retries the CLI attempts on transport errors before aborting with
# E_MCP_UNAVAILABLE (exit 5). Does not retry on timeout. ADR-0010 / spec 0010.
PREOCR_MCP_CONNECT_RETRIES=1

# --- Compose-internal service URLs (generated-agent → MCPs / API) ---
# These resolve via Docker Compose DNS — do NOT use localhost in containers.
OCR_MCP_URL=http://ocr-mcp:8001/sse
RAG_MCP_URL=http://rag-mcp:8002/sse
SCHEDULING_OPENAPI_URL=http://scheduling-api:8000/openapi.json

# --- OCR MCP ---
# Maximum decoded size of the image payload (bytes). Default: 5 MB.
OCR_IMAGE_MAX_BYTES=5242880
# Wall-clock timeout for a single OCR tool call (seconds).
OCR_TIMEOUT_SECONDS=5
# Default language passed to Tesseract when the caller does not specify one.
OCR_DEFAULT_LANGUAGE=pt

# --- RAG MCP ---
# Maximum length of an exam name query (chars).
RAG_QUERY_MAX_CHARS=500
# Wall-clock timeout for a single RAG search call (seconds).
RAG_SEARCH_TIMEOUT_SECONDS=2
# Minimum rapidfuzz score (0–100) to consider a catalog match valid.
RAG_FUZZY_THRESHOLD=80
# Absolute path inside the container where the exam catalog CSV lives.
RAG_CATALOG_PATH=/app/rag_mcp/rag_mcp/data/exams.csv

# --- Scheduling API ---
# Maximum HTTP request body size accepted by the middleware (bytes). Default: 256 KB.
SCHEDULING_BODY_SIZE_LIMIT_BYTES=262144
# Wall-clock timeout for a single scheduling request (seconds).
SCHEDULING_REQUEST_TIMEOUT_SECONDS=10

# --- PII guard (shared across ocr-mcp and generated-agent) ---
# Default language for Presidio analysis when not specified by the caller.
PII_DEFAULT_LANGUAGE=pt
# Maximum text size accepted by pii_mask() (bytes). Default: 100 KB.
PII_TEXT_MAX_BYTES=102400
# Maximum text size accepted by the before_model_callback (bytes). Default: 100 KB.
PII_CALLBACK_TEXT_MAX_BYTES=102400
# Maximum number of items in the PII allow-list.
PII_ALLOW_LIST_MAX=1000
# Wall-clock timeout for a single pii_mask() call (seconds).
PII_TIMEOUT_SECONDS=5
# Minimum Presidio confidence score to mask an entity (0.0–1.0).
PII_SCORE_THRESHOLD=0.5
# spaCy model baked into the image for Portuguese NER. Swap to pt_core_news_sm
# on memory-constrained machines; requires docker compose build (ADR-0009 §K2).
PII_SPACY_MODEL_PT=pt_core_news_lg
# spaCy model baked into the image for English NER.
PII_SPACY_MODEL_EN=en_core_web_lg

# --- Logging (all services) ---
# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
